FROM vllm/vllm-openai:gemma4

# Install RunPod SDK + requests
RUN pip install --no-cache-dir runpod requests

# Copy minimal handler
COPY src/handler_simple.py /src/handler_simple.py

# Default env vars (overridden by RunPod template at runtime)
ENV MODEL_NAME="google/gemma-4-31B-it" \
    HF_HOME="/runpod-volume/huggingface-cache/hub" \
    HUGGINGFACE_HUB_CACHE="/runpod-volume/huggingface-cache/hub"

ENTRYPOINT []
CMD ["python3", "/src/handler_simple.py"]
